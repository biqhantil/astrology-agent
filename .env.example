# ── Astrology Agent — Required Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env && nano .env

# LLM / OpenCode Go API key (required)
OPENCODE_API_KEY=sk-your-key-here

# nginx Basic Auth credentials (required for frontend access)
BASIC_AUTH_USER=bix
BASIC_AUTH_PASS=your-password

# nginx server name (optional, defaults to "localhost")
NGINX_SERVER_NAME=localhost
